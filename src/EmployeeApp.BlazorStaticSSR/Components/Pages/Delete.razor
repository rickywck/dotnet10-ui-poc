@page "/delete/{id:int}"
@using EmployeeCore.Shared.Models
@using EmployeeCore.Shared.Services
@inject IEmployeeRepository Repository
@inject NavigationManager Navigation

<div class="container">
    <div class="header-row">
        <h1>Delete Employee</h1>
        <a href="/" class="btn btn-secondary">Back to List</a>
    </div>

    @if (employee != null)
    {
        <div class="delete-confirmation">
            <h2>Are you sure you want to delete this employee?</h2>

            <div class="employee-details">
                <div class="detail-row">
                    <strong>ID:</strong>
                    <span>@employee.Id</span>
                </div>
                <div class="detail-row">
                    <strong>Name:</strong>
                    <span>@employee.FullName</span>
                </div>
                <div class="detail-row">
                    <strong>Email:</strong>
                    <span>@employee.Email</span>
                </div>
                <div class="detail-row">
                    <strong>Department:</strong>
                    <span>@employee.Department</span>
                </div>
                <div class="detail-row">
                    <strong>Hire Date:</strong>
                    <span>@employee.HireDate:yyyy-MM-dd</span>
                </div>
                <div class="detail-row">
                    <strong>Salary:</strong>
                    <span>@employee.Salary:C</span>
                </div>
            </div>

            <form method="post" action="/delete/@employee.Id?handler=confirm" class="delete-form">
                <button type="submit" class="btn btn-danger">Delete</button>
                <a href="/" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    }
    else
    {
        <div class="empty-state">
            <p>Employee not found.</p>
            <a href="/" class="btn btn-primary">Back to List</a>
        </div>
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private Employee? employee;

    protected override async Task OnInitializedAsync()
    {
        employee = await Repository.GetByIdAsync(Id);
    }
}
